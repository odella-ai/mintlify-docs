{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Odella Docs",
  "description": "Build, hire, and manage AI employees that connect to your tools, automate workflows, and scale business operations without adding headcount.",
  "theme": "almond",
  "logo": {
    "href": "https://www.odella.ai",
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.png",
  "thumbnails": {
    "appearance": "light"
  },
  "colors": {
