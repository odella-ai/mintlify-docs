  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "redirects": [
    {
      "source": "/product/security",
      "destination": "/platform/security",
      "permanent": true
    },
    {
      "source": "/product/models",
      "destination": "/platform/models",
      "permanent": true
    },
    {
      "source": "/product/integrations",
      "destination": "/platform/integrations",
      "permanent": true
    },
    {
      "source": "/product/workforce",
      "destination": "/workforce/overview",
